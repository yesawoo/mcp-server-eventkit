{
  "name": "mcp-server-eventkit",
  "version": "0.1.7",
  "type": "module",
  "description": "Calendar & Reminders for Mac — a Claude Desktop extension for managing macOS calendars and reminders via EventKit",
  "main": "src/index.ts",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "build:swift": "bash src/swift-bridge/build.sh",
    "build:binary": "bun build --compile --outfile build/mcp-eventkit src/index.ts",
    "build:pkg": "./installer/build-pkg.sh",
    "build": "bun run build:swift && bun run build:binary",
    "test": "bun test",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.0",
    "@typescript-eslint/eslint-plugin": "^8.50.0",
    "@typescript-eslint/parser": "^8.50.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "prettier": "^3.7.4",
    "typescript": "^5.3.0"
  },
  "keywords": [
    "mcp",
    "eventkit",
    "reminders",
    "calendar",
    "macos",
    "apple",
    "claude",
    "model-context-protocol"
  ],
  "author": "Alejandro Sánchez Rodríguez",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yesawoo/mcp-server-eventkit.git"
  },
  "bugs": {
    "url": "https://github.com/yesawoo/mcp-server-eventkit/issues"
  },
  "homepage": "https://github.com/yesawoo/mcp-server-eventkit#readme",
  "engines": {
    "bun": ">=1.0.0"
  }
}
