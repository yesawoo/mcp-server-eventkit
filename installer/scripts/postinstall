#!/bin/bash
# MCP EventKit Server - Post Installation Script

set -e

APP_PATH="/Applications/MCP EventKit.app"
BIN_PATH="$APP_PATH/Contents/MacOS/mcp-eventkit"
BIN_LINK="/usr/local/bin/mcp-eventkit"
SETUP_APP="/Applications/MCP EventKit Setup.app"
CLAUDE_CONFIG_DIR="$HOME/Library/Application Support/Claude"
CLAUDE_CONFIG="$CLAUDE_CONFIG_DIR/claude_desktop_config.json"

echo "Configuring MCP EventKit Server..."

# Create /usr/local/bin if it doesn't exist
mkdir -p /usr/local/bin

# Create symlink to binary in app bundle
if [ -L "$BIN_LINK" ]; then
    rm "$BIN_LINK"
fi
ln -sf "$BIN_PATH" "$BIN_LINK"

# Ensure Claude config directory exists
mkdir -p "$CLAUDE_CONFIG_DIR"

# Configure Claude Desktop
if [ -f "$CLAUDE_CONFIG" ]; then
    # Config exists - check if eventkit is already configured
    if grep -q '"eventkit"' "$CLAUDE_CONFIG" 2>/dev/null; then
        echo "EventKit already configured in Claude Desktop"
    else
        # Add eventkit to existing config using Python (available on all Macs)
        python3 << 'PYTHON'
import json
import os

config_path = os.path.expanduser("~/Library/Application Support/Claude/claude_desktop_config.json")

with open(config_path, 'r') as f:
    config = json.load(f)

if 'mcpServers' not in config:
    config['mcpServers'] = {}

config['mcpServers']['eventkit'] = {
    "command": "/usr/local/bin/mcp-eventkit"
}

with open(config_path, 'w') as f:
    json.dump(config, f, indent=2)

print("Added eventkit to Claude Desktop configuration")
PYTHON
    fi
else
    # Create new config
    cat > "$CLAUDE_CONFIG" << 'JSON'
{
  "mcpServers": {
    "eventkit": {
      "command": "/usr/local/bin/mcp-eventkit"
    }
  }
}
JSON
    echo "Created Claude Desktop configuration"
fi

# Open the Setup app to request permissions
if [ -d "$SETUP_APP" ]; then
    echo "Opening MCP EventKit Setup to configure permissions..."
    # Use sudo -u to run as the actual user, not root
    ACTUAL_USER=$(stat -f "%Su" /dev/console)
    sudo -u "$ACTUAL_USER" open "$SETUP_APP"
fi

echo ""
echo "============================================"
echo "  MCP EventKit Server installed!"
echo "============================================"
echo ""
echo "Please grant Calendar and Reminders permissions"
echo "in the Setup window that just opened."
echo ""

exit 0
